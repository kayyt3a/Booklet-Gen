# Copy to .env and fill in. Do NOT commit the real .env.

# --- Required ---
# Session signing key. Use a long random string in production.
FLASK_SECRET_KEY=change-me-to-a-long-random-string

# Google Gemini API key used server-side to generate booklets.
GEMINI_API_KEY=your-gemini-key

# --- Model choice (optional) ---
# Two tiers, picked per call in booklet_gen/agents/*.py:
#   FAST   - only used for outline parsing (simple structured extraction).
#            Cheap model is fine here.
#   STRONG - used for everything quality-sensitive: question generation, the
#            LLM judge that validates correctness, the mini-lesson writer,
#            and the Final Challenge generator. This is the one worth
#            spending on, since it is what checks the answer key is right.
# With billing enabled, gemini-2.5-flash is a good default for STRONG.
# Without billing, both default to the free tier and get rate-limited fast
# (the free tier's per-minute request cap is very low regardless of model) -
# see DEPLOY.md for why billing, not just a cheaper model, is the real fix.
GEMINI_MODEL_STRONG=gemini-2.5-flash
GEMINI_MODEL_FAST=gemini-flash-lite-latest

# --- Data / behaviour (optional) ---
FOLIO_DB=/data/folio.db
FOLIO_OUTPUT=/data/output
