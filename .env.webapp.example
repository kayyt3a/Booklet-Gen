# Copy to .env and fill in. Do NOT commit the real .env.

# --- Required ---
# Session signing key. Use a long random string in production.
FLASK_SECRET_KEY=change-me-to-a-long-random-string

# Google Gemini API key used server-side to generate booklets.
GEMINI_API_KEY=your-gemini-key

# --- Model choice (optional) ---
# Bump to a stronger model for better quality once you have billing.
GEMINI_MODEL_STRONG=gemini-2.5-flash
GEMINI_MODEL_FAST=gemini-flash-lite-latest

# --- Payments (optional; checkout is disabled until these are set) ---
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
# Public URL of your deployed app, used for Stripe redirect URLs.
PUBLIC_BASE_URL=https://your-folio-domain.com

# --- Data / behaviour (optional) ---
FOLIO_DB=/data/folio.db
FOLIO_OUTPUT=/data/output
# Free credits granted to a new account.
FOLIO_SIGNUP_CREDITS=2
