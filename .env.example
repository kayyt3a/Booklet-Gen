# Provider selection: "gemini" or "claude"
LLM_PROVIDER=gemini

# Model names (override per-provider defaults if needed)
GEMINI_MODEL_FAST=gemini-2.5-flash
GEMINI_MODEL_STRONG=gemini-2.5-flash
# On the free tier the flash quota is 20 requests/day. If you hit it,
# switch temporarily to a "lite" model that has its own bucket:
#   GEMINI_MODEL_FAST=gemini-flash-lite-latest
#   GEMINI_MODEL_STRONG=gemini-flash-lite-latest
CLAUDE_MODEL_FAST=claude-haiku-4-5-20251001
CLAUDE_MODEL_STRONG=claude-opus-4-8

# API keys
GEMINI_API_KEY=
ANTHROPIC_API_KEY=

# Retry policy
MAX_RETRIES=3
